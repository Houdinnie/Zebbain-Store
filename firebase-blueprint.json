{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Custom furniture product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "specs": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Shipped", "Delivered"] },
        "popUrl": { "type": "string" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "totalAmount", "status"]
    },
    "User": {
      "title": "User",
      "description": "Registered customer",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "Product saved to user wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of available furniture"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Registered user profiles"
    },
    "wishlist/{wishlistId}": {
      "schema": "WishlistItem",
      "description": "User's saved products"
    }
  }
}
